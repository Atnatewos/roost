# apps/api/.env.example

# Database
DATABASE_URL="postgresql://neondb_owner:npg_iXaWJoKcpA15@ep-mute-brook-asqs38s4-pooler.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-characters
JWT_EXPIRES_IN=30d

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
