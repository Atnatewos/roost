cat << 'EOF' > .gitignore
# Dependencies
node_modules/

# Environment variables (CRITICAL: Never push secrets)
.env
.env.local
.env.*.local
apps/api/.env

# Build output
dist/
build/

# Logs
logs/
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Prisma
apps/api/prisma/*.db
apps/api/prisma/*.db-journal

# Testing
coverage/
EOF